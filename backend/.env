# ============================================================================
# ALERT SETTINGS
# ============================================================================
ALERT_CRITICAL_COOLDOWN_MS=300000
ALERT_WARNING_COOLDOWN_MS=600000
ALERT_INFO_COOLDOWN_MS=1800000
ALERT_ENABLE_ESCALATION_CHAIN=true
ALERT_ESCALATION_TIMEOUT_MS=600000

# ============================================================================
# FEATURE FLAGS
