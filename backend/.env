FEATURE_RAG_ENABLED=true
FEATURE_GEOFENCE_ENABLED=true
FEATURE_COGNITIVE_ENGINE_ENABLED=true
FEATURE_TELEGRAM_ALERTS_ENABLED=true

# ============================================================================
# CORS & SECURITY
# ============================================================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:5174
CORS_CREDENTIALS=true

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_FORMAT=combined
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# ============================================================================
# SOCKET.IO
# ============================================================================
SOCKET_IO_ENABLED=true
SOCKET_IO_CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
DEBUG=mindbridge:*
SEED_DATABASE=false
MOCK_EXTERNAL_APIS=false
DISABLE_RATE_LIMITING=false
DISABLE_AUTHENTICATION=false
VERBOSE_ERROR_MESSAGES=true